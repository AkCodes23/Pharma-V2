# ============================================================
# Pharma Agentic AI — .env.production Template
# ============================================================
# This file documents ALL required environment variables for
# Azure production deployment. Copy to .env.production and
# fill with your actual Key Vault URL.
#
# CRITICAL: In production, secrets are resolved from Azure
# Key Vault at startup. Only KEY_VAULT_URL needs to be set
# here — everything else comes from Key Vault.
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_ENV=production
APP_LOG_LEVEL=INFO

# ── Azure Key Vault (CRITICAL — set this first) ─────────────
KEY_VAULT_URL=https://pharmaai-prod-kv.vault.azure.net/

# ── Feature Flags (Azure services) ──────────────────────────
REDIS_USE_AZURE=true
POSTGRES_USE_AZURE_AD=true
TELEMETRY_USE_AZURE_MONITOR=true
WEB_PUBSUB_USE_AZURE=true
GREMLIN_USE_GREMLIN=true
KAFKA_USE_EVENT_HUBS=true

# ── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://pharmaai.example.com,https://app.pharmaai.example.com

# ── Azure OpenAI (resolved from Key Vault) ───────────────────
# AZURE_OPENAI_API_KEY=       (from Key Vault: azure-openai-api-key)
# AZURE_OPENAI_ENDPOINT=      (from Key Vault: azure-openai-endpoint)
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# ── Cosmos DB (resolved from Key Vault) ──────────────────────
# COSMOS_DB_KEY=               (from Key Vault: cosmos-db-key)
# COSMOS_DB_ENDPOINT=          (from Key Vault: cosmos-db-endpoint)
COSMOS_DB_DATABASE_NAME=pharma_agentic_ai

# ── Service Bus (resolved from Key Vault) ────────────────────
# SERVICE_BUS_CONNECTION_STRING=  (from Key Vault: service-bus-connection-string)
SERVICE_BUS_LEGAL_TOPIC=legal-tasks
SERVICE_BUS_CLINICAL_TOPIC=clinical-tasks
SERVICE_BUS_COMMERCIAL_TOPIC=commercial-tasks
SERVICE_BUS_SOCIAL_TOPIC=social-tasks
SERVICE_BUS_KNOWLEDGE_TOPIC=knowledge-tasks
SERVICE_BUS_NEWS_TOPIC=news-tasks

# ── Blob Storage (resolved from Key Vault) ───────────────────
# BLOB_STORAGE_CONNECTION_STRING=  (from Key Vault: blob-storage-connection-string)
BLOB_STORAGE_REPORTS_CONTAINER=reports

# ── AI Search (resolved from Key Vault) ──────────────────────
# AI_SEARCH_API_KEY=           (from Key Vault: ai-search-api-key)
# AI_SEARCH_ENDPOINT=         (from Key Vault: ai-search-endpoint)
AI_SEARCH_INDEX_NAME=pharma-knowledge

# ── Redis (resolved from Key Vault) ──────────────────────────
# REDIS_URL=                   (from Key Vault: redis-url)

# ── PostgreSQL (resolved from Key Vault) ─────────────────────
# POSTGRES_URL=                (from Key Vault: postgres-url)

# ── AI Language (NER) (resolved from Key Vault) ──────────────
# AI_LANGUAGE_API_KEY=         (from Key Vault: ai-language-api-key)
# AI_LANGUAGE_ENDPOINT=        (from Key Vault: ai-language-endpoint)

# ── Web PubSub (resolved from Key Vault) ─────────────────────
# WEB_PUBSUB_CONNECTION_STRING=  (from Key Vault: web-pubsub-connection-string)

# ── Gremlin/Graph (resolved from Key Vault) ──────────────────
# GREMLIN_KEY=                 (from Key Vault: gremlin-key)
# GREMLIN_ENDPOINT=            (from Key Vault: gremlin-endpoint)

# ── Telemetry (resolved from Key Vault) ──────────────────────
# TELEMETRY_APPLICATION_INSIGHTS_CONNECTION_STRING=  (from Key Vault: telemetry-connection-string)

# ── Kafka/Event Hubs ─────────────────────────────────────────
# KAFKA_EVENT_HUBS_CONNECTION_STRING=  (from Key Vault: kafka-event-hubs-connection-string)
KAFKA_BOOTSTRAP_SERVERS=pharma-events.servicebus.windows.net:9093

# ── Tavily (News retriever) ──────────────────────────────────
# TAVILY_API_KEY=              (from Key Vault: tavily-api-key)

# ── Internal API Key (for MCP Server → Planner communication) ─
# PHARMA_INTERNAL_API_KEY=     (from Key Vault or generate manually)

# ── Celery Broker ────────────────────────────────────────────
CELERY_BROKER_URL=rediss://:password@pharmaai-prod-redis.redis.cache.windows.net:6380/1
CELERY_RESULT_BACKEND=rediss://:password@pharmaai-prod-redis.redis.cache.windows.net:6380/2
