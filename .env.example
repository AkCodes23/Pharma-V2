# ============================================================
# Pharma Agentic AI — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ============================================================

# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=https://your-instance.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# --- Azure Cosmos DB ---
COSMOS_DB_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_DB_KEY=your-cosmos-key
COSMOS_DB_DATABASE_NAME=pharma_agentic_ai
COSMOS_DB_SESSION_CONTAINER=sessions
COSMOS_DB_AUDIT_CONTAINER=audit_trail

# --- Azure Service Bus (production only — Kafka used locally) ---
SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://your-bus.servicebus.windows.net/;SharedAccessKeyName=...
SERVICE_BUS_LEGAL_TOPIC=legal-tasks
SERVICE_BUS_CLINICAL_TOPIC=clinical-tasks
SERVICE_BUS_COMMERCIAL_TOPIC=commercial-tasks
SERVICE_BUS_SOCIAL_TOPIC=social-tasks
SERVICE_BUS_KNOWLEDGE_TOPIC=knowledge-tasks

# --- Azure Key Vault ---
KEY_VAULT_URL=https://your-keyvault.vault.azure.net/

# --- Azure Blob Storage ---
BLOB_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
BLOB_STORAGE_REPORTS_CONTAINER=reports

# --- Azure AI Search (Private RAG) ---
AI_SEARCH_ENDPOINT=https://your-search.search.windows.net
AI_SEARCH_INDEX_NAME=pharma-internal-docs
AI_SEARCH_API_KEY=your-search-key

# --- External API Keys (stored in Key Vault in production) ---
USPTO_API_KEY=your-uspto-key
FDA_FAERS_API_KEY=your-faers-key

# --- Application Settings ---
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_MAX_RETRIES=3
APP_RETRY_BACKOFF_BASE=2
APP_SESSION_TIMEOUT_SECONDS=600
APP_MAX_AGENTS_PER_QUERY=50

# ============================================================
# NEW: Docker Infrastructure Services
# ============================================================

# --- Redis ---
REDIS_URL=redis://:pharma_redis_2026@localhost:6379/0
REDIS_PASSWORD=pharma_redis_2026
REDIS_MAX_CONNECTIONS=50
REDIS_SESSION_CACHE_TTL=600
REDIS_RESULT_CACHE_TTL=86400

# --- PostgreSQL ---
POSTGRES_URL=postgresql://pharma:pharma_pg_2026@localhost:5432/pharma_ai
POSTGRES_PASSWORD=pharma_pg_2026
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# --- Celery ---
CELERY_BROKER_URL=redis://:pharma_redis_2026@localhost:6379/1
CELERY_RESULT_BACKEND=db+postgresql://pharma:pharma_pg_2026@localhost:5432/celery_results

# --- RAG ---
RAG_EMBEDDING_MODEL=text-embedding-ada-002
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_VECTOR_STORE=chromadb
RAG_TOP_K=5

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
