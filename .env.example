# ─────────────────────────────────────────────────────────
# Pharma Agentic AI — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────
APP_ENV=development
APP_LOG_LEVEL=INFO

# ── Azure OpenAI (REQUIRED) ─────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ── Azure Cosmos DB (REQUIRED) ──────────────────────────
COSMOS_DB_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOS_DB_KEY=your-primary-key
COSMOS_DB_DATABASE_NAME=pharma_agentic_ai

# ── Azure Service Bus (REQUIRED) ────────────────────────
SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=...

# ── Azure Key Vault ─────────────────────────────────────
KEY_VAULT_URL=https://your-keyvault.vault.azure.net/

# ── Azure Blob Storage ──────────────────────────────────
BLOB_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# ── Azure AI Search ─────────────────────────────────────
AI_SEARCH_ENDPOINT=https://your-search.search.windows.net
AI_SEARCH_API_KEY=your-admin-key

# ── Azure AI Language (NER) ─────────────────────────────
AI_LANGUAGE_ENDPOINT=https://your-language.cognitiveservices.azure.com
AI_LANGUAGE_API_KEY=your-api-key

# ── Azure Web PubSub ────────────────────────────────────
WEB_PUBSUB_USE_AZURE=false
WEB_PUBSUB_CONNECTION_STRING=Endpoint=https://your-pubsub.webpubsub.azure.com;AccessKey=...;Version=1.0;

# ── Azure Cosmos DB Gremlin (Knowledge Graph) ───────────
GREMLIN_USE_GREMLIN=false
GREMLIN_ENDPOINT=your-account.gremlin.cosmos.azure.com
GREMLIN_KEY=your-primary-key
GREMLIN_DATABASE=pharma-graph
GREMLIN_GRAPH=entities

# ── Azure Monitor / Application Insights ────────────────
TELEMETRY_USE_AZURE_MONITOR=false
TELEMETRY_APPLICATION_INSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...

# ── Redis (local dev or Azure Cache for Redis) ──────────
REDIS_URL=redis://localhost:6379/0
REDIS_USE_AZURE=false
REDIS_AZURE_HOST=

# ── PostgreSQL (local dev or Azure Flexible Server) ─────
POSTGRES_URL=postgresql://pharma:pharma_pg_2026@localhost:5432/pharma_ai
POSTGRES_SSL_MODE=prefer
POSTGRES_USE_AZURE_AD=false

# ── Kafka (local dev only) ──────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Tavily Web Search (optional) ────────────────────────
TAVILY_API_KEY=

# ── NEO4J (local dev graph) ─────────────────────────────
NEO4J_BOLT_URL=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=pharma_neo4j_2026

# ── Celery ──────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=db+postgresql://pharma:pharma_pg_2026@localhost:5432/celery_results

# ── RAG ─────────────────────────────────────────────────
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_CHUNK_SIZE=512
RAG_TOP_K=5
