# Standalone demo configuration (no Azure dependencies)
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_MODE=standalone_demo
DEMO_OFFLINE=true

DATA_STORE_PROVIDER=postgres
TASK_BUS_PROVIDER=kafka
OBJECT_STORE_PROVIDER=minio
LLM_PROVIDER=fixture
KNOWLEDGE_PROVIDER=fixture
AUTH_MODE=anonymous

POSTGRES_URL=postgresql://pharma:pharma_pg_2026@postgres:5432/pharma_ai
REDIS_URL=redis://redis:6379/0
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=reports
MINIO_SECURE=false
MINIO_PUBLIC_URL=http://localhost:9000

SUPERVISOR_URL=http://supervisor:8001
EXECUTOR_URL=http://executor:8002

PHARMA_INTERNAL_API_KEY=demo-internal-key
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
